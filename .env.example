# ─── Sanity CMS ───────────────────────────────────────────────────────────────
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production
SANITY_API_TOKEN=                     # server-side only — never expose to browser

# ─── Supabase ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=            # server-side only — never expose to browser

# ─── Stripe ───────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=                # from Stripe dashboard → Webhooks

# ─── Resend (email) ───────────────────────────────────────────────────────────
RESEND_API_KEY=
RESEND_FROM_EMAIL=hello@yourdomain.com
RESEND_SELLER_EMAIL=owner@yourdomain.com   # where order notifications are sent

# ─── App ──────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=http://localhost:3000  # change to https://yourdomain.com in prod

# ─── Admin ────────────────────────────────────────────────────────────────────
ADMIN_PASSWORD=                       # simple password for /admin/orders page
